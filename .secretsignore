# .secretsignore — False positive exclusions for check_no_plaintext_secrets.sh
# Lines starting with # are comments. Patterns match against file paths.

# Example and template files (contain illustrative patterns, not real secrets)
.example
.template
env.template

# Documentation files that reference secret patterns
docs/
diagrams/

# SOPS-encrypted files (already encrypted)
.enc.yaml
.enc.yml
.enc.json

# Vault policy files (contain path patterns, not secrets)
platform/vault/policies/
platform/vault/examples/

# Test fixtures
tests/fixtures/

# The secret scanner itself
check_no_plaintext_secrets.sh

# OPA/Rego policy files (contain pattern definitions)
.rego

# Pre-commit configuration
.pre-commit-config.yaml

# Cloud-init templates
cloud-init-vault-agent.yaml

# Vault Agent HCL configs (contain template syntax, not secrets)
vault-agent-vm.hcl
