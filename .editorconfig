root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.{yaml,yml}]
indent_style = space
indent_size = 2

[*.{tf,hcl}]
indent_style = space
indent_size = 2

[*.{sh,bash}]
indent_style = space
indent_size = 2

[*.{md,markdown}]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{json,jsonnet}]
indent_style = space
indent_size = 2

[*.rego]
indent_style = tab
