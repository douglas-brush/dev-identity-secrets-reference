# Local development environment configuration.
# Copy to .env and modify as needed: cp .env.example .env

# ── Vault ────────────────────────────────────────────────────────────
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-root-token
VAULT_DEV_ROOT_TOKEN=dev-root-token
VAULT_PORT=8200
VAULT_LOG_LEVEL=info

# ── Vault Agent ──────────────────────────────────────────────────────
VAULT_AGENT_PORT=8100

# ── PostgreSQL ───────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=demo
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# ── Prometheus (monitoring profile) ─────────────────────────────────
PROMETHEUS_PORT=9090

# ── Grafana (monitoring profile) ────────────────────────────────────
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ── Application (for use with lib/python SDK) ───────────────────────
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/demo
# APP_ENV=development
