%% Attack Tree: Compromise a Production Secret
%% Reference: docs/24-attack-trees.md
%%
%% Color coding by residual risk:
%%   Red (#ff6b6b)    = High residual risk
%%   Orange (#ffa94d)  = Medium residual risk
%%   Blue (#74c0fc)    = Low residual risk
%%   Green (#b2f2bb)   = Very Low residual risk

graph TD
    ROOT["<b>ROOT GOAL</b><br/>Compromise a<br/>Production Secret"]

    %% ── Branch 1: Source Control ──
    ROOT --> SC["1. Extract from<br/>Source Control"]

    SC --> SC1["1.1 Plaintext<br/>committed to Git"]
    SC --> SC2["1.2 Decrypt<br/>SOPS-encrypted file"]
    SC --> SC3["1.3 Secret persists<br/>in Git history"]

    SC1 --> SC1a["1.1.1 Developer uses<br/>--no-verify to<br/>bypass pre-commit"]
    SC1 --> SC1b["1.1.2 Secret type<br/>not covered by<br/>gitleaks regex"]
    SC1 --> SC1c["1.1.3 Secret embedded<br/>in binary or<br/>image file"]

    SC2 --> SC2a["1.2.1 Compromise<br/>developer age key<br/>(laptop theft)"]
    SC2 --> SC2b["1.2.2 Compromise<br/>break-glass key<br/>(physical breach)"]
    SC2 --> SC2c["1.2.3 Obtain cloud<br/>KMS decrypt via<br/>IAM escalation"]

    %% ── Branch 2: CI/CD Pipeline ──
    ROOT --> CI["2. Extract from<br/>CI/CD Pipeline"]

    CI --> CI1["2.1 Read CI<br/>env vars or logs"]
    CI --> CI2["2.2 Abuse OIDC<br/>federation trust"]

    CI1 --> CI1a["2.1.1 Inject malicious<br/>workflow step to<br/>exfiltrate env vars"]
    CI1 --> CI1b["2.1.2 Secret leaked<br/>to build log<br/>(debug/error trace)"]
    CI1 --> CI1c["2.1.3 Stolen PAT or<br/>SSO bypass to<br/>CI admin console"]

    CI2 --> CI2a["2.2.1 Branch matches<br/>overly broad<br/>subject claim"]
    CI2 --> CI2b["2.2.2 Fork inherits<br/>OIDC trust from<br/>parent repo"]

    %% ── Branch 3: Runtime Environment ──
    ROOT --> RT["3. Extract from<br/>Runtime Environment"]

    RT --> RT1["3.1 Read Kubernetes<br/>Secret objects"]
    RT --> RT2["3.2 Intercept Vault<br/>lease or token"]
    RT --> RT3["3.3 Memory dump of<br/>running process"]

    RT1 --> RT1a["3.1.1 RBAC grants<br/>cross-namespace<br/>secret read"]
    RT1 --> RT1b["3.1.2 Compromised pod<br/>with mounted<br/>service account"]
    RT1 --> RT1c["3.1.3 etcd backup<br/>accessed without<br/>encryption at rest"]

    RT2 --> RT2a["3.2.1 Token logged<br/>in application<br/>debug output"]
    RT2 --> RT2b["3.2.2 Network intercept<br/>(missing mTLS<br/>to Vault)"]

    %% ── Branch 4: Social Engineering ──
    ROOT --> SE["4. Social Engineering<br/>/ Insider"]

    SE --> SE1["4.1 Coerce developer<br/>with prod access"]
    SE --> SE2["4.2 Malicious insider<br/>exports secrets<br/>via legitimate access"]
    SE --> SE3["4.3 Third-party vendor<br/>with delegated<br/>access compromised"]

    %% ── Branch 5: Vault Direct ──
    ROOT --> VD["5. Compromise<br/>Vault Directly"]

    VD --> VD1["5.1 Exploit Vault<br/>software CVE"]
    VD --> VD2["5.2 Steal Vault<br/>root token"]
    VD --> VD3["5.3 Obtain 3-of-5<br/>Shamir unseal keys"]

    %% ── Branch 6: Supply Chain ──
    ROOT --> SCA["6. Supply Chain<br/>Attack"]

    SCA --> SCA1["6.1 Compromised<br/>dependency exfils<br/>env vars at build"]
    SCA --> SCA2["6.2 Malicious<br/>container base<br/>image with backdoor"]
    SCA --> SCA3["6.3 Trojanized SOPS<br/>or Vault binary"]

    %% ── Styling ──
    classDef root fill:#495057,stroke:#212529,color:#fff,font-weight:bold
    classDef branch fill:#868e96,stroke:#495057,color:#fff
    classDef high fill:#ff6b6b,stroke:#c92a2a,color:#fff
    classDef medium fill:#ffa94d,stroke:#e8590c,color:#fff
    classDef low fill:#74c0fc,stroke:#1971c2,color:#fff
    classDef verylow fill:#b2f2bb,stroke:#2f9e44,color:#000

    class ROOT root
    class SC,CI,RT,SE,VD,SCA branch
    class SC1,CI1,CI2,RT1,RT2 branch

    %% Leaf node risk coloring
    class SC1a,CI1a,CI2a,RT1a,RT1b,SC2a,RT2a medium
    class CI1b high
    class SC1b,SC1c,SC2c,CI1c,CI2b,RT1c,RT3,SE1,VD1,SCA2 low
    class SC2b,SC3,RT2b,VD2,VD3,SCA3 verylow
    class SE2,SE3,SCA1 medium
