###############################################################################
# Dev Environment — Example Variable Values
# Copy to terraform.tfvars and fill in your values.
# NEVER commit terraform.tfvars — it may contain secrets.
###############################################################################

# -----------------------------------------------------------------------------
# GitHub Configuration
# -----------------------------------------------------------------------------

github_org    = "my-org"
allowed_repos = ["my-app", "my-infra", "my-platform"]

# -----------------------------------------------------------------------------
# AWS
# -----------------------------------------------------------------------------

aws_region  = "us-east-1"
aws_secrets = ["database-url", "api-key", "jwt-secret"]

# -----------------------------------------------------------------------------
# Azure
# -----------------------------------------------------------------------------

azure_resource_group_name        = "rg-dev-identity-secrets"
azure_location                   = "eastus"
azure_key_vault_name             = "kv-dev-identsecrets" # Must be globally unique
azure_log_analytics_workspace_id = "" # Fill in if you have one

# -----------------------------------------------------------------------------
# GCP
# -----------------------------------------------------------------------------

gcp_project_id  = "my-gcp-project-dev"
gcp_region      = "us-central1"
gcp_secrets     = ["database-url", "api-key"]
gcp_enable_apis = true

# -----------------------------------------------------------------------------
# Vault (optional — set enable_vault = true to activate)
# -----------------------------------------------------------------------------

enable_vault  = false
vault_address = "https://vault.example.com:8200"

# Vault engines — enable as needed
vault_enable_database = false
vault_enable_pki      = false
vault_enable_ssh      = false
vault_enable_transit  = true
vault_enable_oidc     = false

# OIDC (for human Vault login — requires vault_enable_oidc = true)
# oidc_discovery_url         = "https://accounts.google.com"
# oidc_client_id             = "your-client-id.apps.googleusercontent.com"
# oidc_client_secret         = "your-client-secret"  # Use env var TF_VAR_oidc_client_secret instead
# oidc_allowed_redirect_uris = [
#   "https://vault.example.com:8200/ui/vault/auth/oidc/oidc/callback",
#   "http://localhost:8250/oidc/callback",
# ]

# PKI
pki_organization = "My Organization"
pki_domains      = ["dev.example.com", "internal.example.com"]

# Kubernetes auth (requires vault_enable_kubernetes = true)
vault_enable_kubernetes = false
# kubernetes_host         = "https://kubernetes.default.svc:6443"
# kubernetes_ca_cert      = "" # Base64-decoded CA cert
# kubernetes_roles = {
#   "my-app" = {
#     service_account_names = ["my-app"]
#     namespaces            = ["my-app-dev"]
#     policies              = ["secrets-reader", "github-actions-dev"]
#     token_ttl             = 3600
#     token_max_ttl         = 86400
#   }
# }
