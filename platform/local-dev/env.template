# =============================================================================
# Dev Identity & Secrets Reference Architecture — Environment Template
#
# Copy to .env and replace all REPLACE_* placeholders with real values.
# NEVER commit .env files — they must be in .gitignore.
#
# Where to find each value is documented inline.
# =============================================================================

# =============================================================================
# Vault
# Source: Your organization's Vault deployment or `vault server -dev` locally
# =============================================================================
VAULT_ADDR=REPLACE_VAULT_URL                     # e.g. http://127.0.0.1:8200 or https://vault.example.com
VAULT_ROLE=REPLACE_VAULT_ROLE                     # Vault auth role name — ask your platform team
VAULT_AUTH_PATH=REPLACE_AUTH_PATH                  # Auth mount path: oidc, ldap, github, etc.
# VAULT_TOKEN=                                    # Auto-set by `vault login` — do not hardcode
# VAULT_NAMESPACE=REPLACE_NAMESPACE               # Enterprise only — e.g. admin/dev

# =============================================================================
# SOPS / Encryption
# Source: Generate age key with `age-keygen -o ~/.config/sops/age/keys.txt`
#         PGP fingerprint from `gpg --list-keys`
#         KMS ARNs from your cloud provider console
# =============================================================================
SOPS_AGE_KEY_FILE=REPLACE_AGE_KEY_PATH            # e.g. ${HOME}/.config/sops/age/keys.txt
# SOPS_AGE_RECIPIENTS=REPLACE_AGE_PUBLIC_KEY      # age1... — public key for encrypting
# SOPS_PGP_FP=REPLACE_PGP_FINGERPRINT             # GPG fingerprint (alternative to age)
# SOPS_KMS_ARN=REPLACE_AWS_KMS_ARN                # AWS KMS key ARN
# SOPS_GCP_KMS_IDS=REPLACE_GCP_KMS_RESOURCE_ID    # GCP KMS resource ID
# SOPS_AZURE_KEYVAULT_URLS=REPLACE_AZURE_KV_URL   # Azure Key Vault URL

# =============================================================================
# Application
# Source: Project configuration / your choice for local dev
# =============================================================================
APP_NAME=REPLACE_APP_NAME                          # e.g. demo-app
APP_ENV=REPLACE_ENVIRONMENT                        # dev, staging, prod
APP_PORT=REPLACE_APP_PORT                          # e.g. 8080
LOG_LEVEL=REPLACE_LOG_LEVEL                        # debug, info, warn, error
LOG_FORMAT=REPLACE_LOG_FORMAT                      # json or text

# =============================================================================
# Database
# Source: Dynamic credentials from Vault database engine or local dev DB
# =============================================================================
DB_HOST=REPLACE_DB_HOST                            # e.g. localhost
DB_PORT=REPLACE_DB_PORT                            # e.g. 5432 (Postgres), 3306 (MySQL)
DB_NAME=REPLACE_DB_NAME                            # e.g. myapp_dev
DB_SSLMODE=REPLACE_DB_SSLMODE                      # disable, require, verify-ca, verify-full
# DB_USERNAME=                                     # Set by Vault dynamic credentials
# DB_PASSWORD=                                     # Set by Vault dynamic credentials

# =============================================================================
# Redis
# Source: Local Redis or Vault KV for password
# =============================================================================
REDIS_HOST=REPLACE_REDIS_HOST                      # e.g. localhost
REDIS_PORT=REPLACE_REDIS_PORT                      # e.g. 6379
# REDIS_PASSWORD=                                  # Set by Vault KV

# =============================================================================
# Message Queue
# Source: Vault KV or local broker
# =============================================================================
# RABBITMQ_URL=REPLACE_RABBITMQ_URL               # e.g. amqp://guest:guest@localhost:5672/
# KAFKA_BROKERS=REPLACE_KAFKA_BROKERS             # Comma-separated: host1:9092,host2:9092

# =============================================================================
# Object Storage / Cloud Credentials
# Source: Vault AWS/GCP/Azure secrets engine for dynamic cloud credentials
# =============================================================================
# AWS_ACCESS_KEY_ID=                               # Set by Vault AWS secrets engine
# AWS_SECRET_ACCESS_KEY=                           # Set by Vault AWS secrets engine
# AWS_REGION=REPLACE_AWS_REGION                    # e.g. us-east-1
# S3_BUCKET=REPLACE_S3_BUCKET                      # e.g. my-app-dev-assets

# =============================================================================
# API Keys & External Services
# Source: Vault KV — path: kv/<env>/apps/<app>/config
# =============================================================================
# API_KEY=                                         # Set by Vault KV
# EXTERNAL_API_URL=REPLACE_API_URL                 # e.g. https://api.example.com/v1
# WEBHOOK_SECRET=                                  # Set by Vault KV

# =============================================================================
# Auth / Identity (OIDC)
# Source: Your identity provider (Keycloak, Okta, Auth0, Azure AD)
# =============================================================================
# OIDC_CLIENT_ID=REPLACE_OIDC_CLIENT_ID           # From IdP app registration
# OIDC_CLIENT_SECRET=                              # Set by Vault KV — never hardcode
# OIDC_ISSUER_URL=REPLACE_OIDC_ISSUER             # e.g. https://auth.example.com/realms/dev

# =============================================================================
# Observability
# Source: Your observability stack or local OTEL collector
# =============================================================================
# OTEL_EXPORTER_OTLP_ENDPOINT=REPLACE_OTEL_ENDPOINT  # e.g. http://localhost:4317
# OTEL_SERVICE_NAME=REPLACE_SERVICE_NAME              # e.g. ${APP_NAME}
# PROMETHEUS_PORT=REPLACE_PROM_PORT                    # e.g. 9090

# =============================================================================
# Kubernetes
# Source: kubeconfig file, kubectl context
# =============================================================================
# KUBECONFIG=REPLACE_KUBECONFIG_PATH               # e.g. ${HOME}/.kube/config
# K8S_NAMESPACE=REPLACE_K8S_NAMESPACE              # e.g. default

# =============================================================================
# CI/CD
# Source: CI provider environment (GitHub Actions, GitLab CI, etc.)
# These are typically set by the CI system, not by developers locally.
# =============================================================================
# GITHUB_TOKEN=                                    # Set in CI environment — never local
# GITHUB_ORG=REPLACE_GITHUB_ORG                    # e.g. my-org
# DOCKER_REGISTRY=REPLACE_DOCKER_REGISTRY          # e.g. ghcr.io/my-org
# CI_VAULT_ROLE=REPLACE_CI_VAULT_ROLE              # Vault role for CI workload identity
# CI_VAULT_AUTH_PATH=REPLACE_CI_AUTH_PATH           # e.g. jwt/github-actions

# =============================================================================
# Transit Encryption (Vault Transit Engine)
# Source: Vault transit engine setup
# =============================================================================
# TRANSIT_KEY_NAME=REPLACE_TRANSIT_KEY             # e.g. app-encryption-key
# TRANSIT_MOUNT_PATH=REPLACE_TRANSIT_MOUNT         # e.g. transit (default)

# =============================================================================
# PKI / TLS Certificates
# Source: Vault PKI engine
# =============================================================================
# PKI_ROLE=REPLACE_PKI_ROLE                        # e.g. dev-server
# PKI_MOUNT_PATH=REPLACE_PKI_MOUNT                 # e.g. pki_int
# PKI_COMMON_NAME=REPLACE_PKI_CN                   # e.g. myapp.dev.internal
