# =============================================================================
# Dev Identity & Secrets — Environment Template
# Copy to .env and fill in values. NEVER commit .env files.
# =============================================================================

# --- Vault ---
VAULT_ADDR=https://vault.example.internal:8200
VAULT_ROLE=developer
VAULT_AUTH_PATH=oidc
# VAULT_TOKEN=               # Set automatically by vault login
# VAULT_NAMESPACE=           # Enterprise only

# --- SOPS / Encryption ---
SOPS_AGE_KEY_FILE=${HOME}/.config/sops/age/keys.txt
# SOPS_AGE_RECIPIENTS=       # Public key for encrypting (age1...)
# SOPS_PGP_FP=               # PGP fingerprint (if using GPG instead of age)
# SOPS_KMS_ARN=              # AWS KMS ARN for SOPS
# SOPS_GCP_KMS_IDS=          # GCP KMS resource ID
# SOPS_AZURE_KEYVAULT_URLS=  # Azure Key Vault URL

# --- Application ---
APP_NAME=demo-app
APP_ENV=dev
APP_PORT=8080
LOG_LEVEL=debug
LOG_FORMAT=json

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=demo
DB_SSLMODE=require
# DB_USERNAME=               # Set by Vault dynamic credentials
# DB_PASSWORD=               # Set by Vault dynamic credentials

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=            # Set by Vault

# --- Message Queue ---
# RABBITMQ_URL=              # Set by Vault
# KAFKA_BROKERS=             # Comma-separated broker list

# --- Object Storage ---
# AWS_ACCESS_KEY_ID=         # Set by Vault AWS secrets engine
# AWS_SECRET_ACCESS_KEY=     # Set by Vault AWS secrets engine
# AWS_REGION=us-east-1
# S3_BUCKET=my-app-dev

# --- API Keys ---
# API_KEY=                   # Set by Vault KV
# EXTERNAL_API_URL=          # Set by Vault KV
# WEBHOOK_SECRET=            # Set by Vault KV

# --- Auth / Identity ---
# OIDC_CLIENT_ID=            # Set by Vault KV
# OIDC_CLIENT_SECRET=        # Set by Vault KV
# OIDC_ISSUER_URL=           # IdP discovery URL

# --- Observability ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=${APP_NAME}
# PROMETHEUS_PORT=9090

# --- Kubernetes (if applicable) ---
# KUBECONFIG=${HOME}/.kube/config
# K8S_NAMESPACE=default

# --- CI/CD ---
# GITHUB_TOKEN=              # Set in CI environment
# GITHUB_ORG=my-org
# DOCKER_REGISTRY=ghcr.io/my-org
